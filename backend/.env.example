APP_NAME=GoldMarket
APP_ENV=production
DEBUG=false

# PostgreSQL — Railway provides this automatically
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname
POSTGRES_USER=goldmarket
POSTGRES_PASSWORD=your-db-password
POSTGRES_DB=goldmarket_db

# Redis — Railway provides this automatically
REDIS_URL=redis://host:6379/0

# JWT — generate a strong random string (32+ chars)
SECRET_KEY=change-this-to-a-long-random-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# Razorpay — use live keys in production
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_live_secret

# CORS — your Vercel frontend URL (comma-separated if multiple)
ALLOWED_ORIGINS=https://your-app.vercel.app
