# ── Database ──────────────────────────────────────────────
POSTGRES_USER=goldmarket
POSTGRES_PASSWORD=goldmarket123
POSTGRES_DB=goldmarket_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://goldmarket:goldmarket123@localhost:5432/goldmarket_db

# ── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── JWT ───────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-long-random-secret-key-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Razorpay ──────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_secret

# ── Google Maps ───────────────────────────────────────────
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# ── App ───────────────────────────────────────────────────
APP_NAME=GoldMarket
APP_ENV=development
DEBUG=true
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# ── Gold Rate (optional external API) ────────────────────
GOLD_API_KEY=your_gold_api_key_if_using_external_feed
